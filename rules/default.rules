prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "rm", "--cached"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "pull", "--ff-only"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "origin"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "project", "view"], decision="allow")
prefix_rule(pattern=["gh", "project", "item-list"], decision="allow")
prefix_rule(pattern=["gh", "project", "link"], decision="allow")
prefix_rule(pattern=["gh", "project", "create"], decision="allow")
prefix_rule(pattern=["gh", "api", "graphql"], decision="allow")
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["pnpm", "view", "pnpm", "version"], decision="allow")
prefix_rule(pattern=["pnpm", "security:deps"], decision="allow")
prefix_rule(pattern=["pnpm", "test:integration"], decision="allow")
prefix_rule(pattern=["npm", "test", "--", "--run"], decision="allow")
prefix_rule(pattern=["npm", "run", "-s", "build"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev"], decision="allow")
prefix_rule(pattern=["corepack", "prepare", "pnpm@10.33.0", "--activate"], decision="allow")
prefix_rule(pattern=["docker", "info"], decision="allow")
prefix_rule(pattern=["docker", "ps", "-a"], decision="allow")
prefix_rule(pattern=["docker", "network", "ls"], decision="allow")
prefix_rule(pattern=["npx", "supabase@latest"], decision="allow")
prefix_rule(pattern=["supabase", "start"], decision="allow")
prefix_rule(pattern=["supabase", "status"], decision="allow")
prefix_rule(pattern=["supabase", "stop", "--all", "--no-backup"], decision="allow")
prefix_rule(pattern=["supabase", "db", "reset"], decision="allow")
prefix_rule(pattern=["./scripts/codex-caveman-exec.sh"], decision="allow")
