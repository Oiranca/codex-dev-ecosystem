{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CODEX_HOME:-$HOME/.codex}/hooks/session_start_log.py",
            "timeout": 5,
            "statusMessage": "Logging session start"
          },
          {
            "type": "command",
            "command": "python3 ${CODEX_HOME:-$HOME/.codex}/scripts/caveman_ultra_prompt.py --emit",
            "timeout": 5,
            "statusMessage": "Loading caveman ultra"
          }
        ]
      }
    ]
  }
}
